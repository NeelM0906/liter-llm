# frozen_string_literal: true

require 'bundler/gem_tasks'
require 'rake/extensiontask'
require 'rspec/core/rake_task'

GEMSPEC = Gem::Specification.load(File.expand_path('liter_llm.gemspec', __dir__))

# Vendor liter-llm core crates before compilation
task :vendor do
  vendor_script = File.expand_path('../../scripts/ci/ruby/vendor-liter-llm-core.py', __dir__)
  puts 'Vendoring liter-llm core crates...'
  sh "python3 #{vendor_script}"
end

Rake::ExtensionTask.new('liter_llm_rb', GEMSPEC) do |ext|
  ext.lib_dir = 'lib'
  ext.ext_dir = 'ext/liter_llm_rb'
  ext.cross_compile = true
  ext.cross_platform = %w[
    x86_64-linux
    aarch64-linux
    x86_64-darwin
    arm64-darwin
    x64-mingw32
    x64-mingw-ucrt
  ]
end

RSpec::Core::RakeTask.new(:spec) do |t|
  t.rspec_opts = '--format documentation'
end

task compile: :vendor
task spec: :compile
task default: :spec
